  url = {https://www.annualreviews.org/content/journals/10.1146/annurev-polisci-051120-103015},
  urldate = {2026-05-14},
  abstract = {The public\&apos;s health is intimately linked to politics and policy. But political science has yet to make a major contribution to understanding the political economy of health (as distinct from medical care). In order to advance understanding of the drivers of health in an era of emerging infectious disease and global pandemics, more political scientists must begin to do what we are uniquely well situated to do: analyze in a contextualized way the pathways and mechanisms through which power configurations cause illness and inequity. This article reviews key findings from recent literature about the policy, political, and structural contributors to population health and health equity and sketches what a political economy of health more deeply rooted in political science could look like.},
  issue = {Volume 26, 2023},
  langid = {english},
  file = {C\:\\Users\\cmeji\\OneDrive\\Escritorio\\bibliografia-2026\\Lynch - 2023 - Political Economy Health\\Lynch - 2023 - Political Economy Health.pdf;C\:\\Users\\cmeji\\Zotero\\storage\\H3DZE7VG\\annurev-polisci-051120-103015.html}
}

@article{madariaga_three_2020,
  title = {The Three Pillars of Neoliberalism: {{Chile}}’s Economic Policy Trajectory in Comparative Perspective},
  shorttitle = {The Three Pillars of Neoliberalism},
  author = {Madariaga, Aldo},
  date = {2020-05-26},
  journaltitle = {Contemporary Politics},
  volume = {26},
