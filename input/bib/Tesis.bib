  urldate = {2026-06-30},
  abstract = {Perceptions of economic inequality have become a topic of growing interest in research from different social science disciplines. This article presents an up-to-date literature review of studies on this topic, stressing aspects related to its conceptualization and measurement, as well as psychosocial, socioeconomic and contextual factors associated with the perception of inequality. This review ends by pointing out some consequences of perception of inequality and identifying some pathways for future research agendas},
